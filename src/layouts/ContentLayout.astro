---
import BaseLayout from './BaseLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';

interface Props {
  title: string;
  description: string;
  breadcrumbs: Array<{ label: string; href: string }>;
  lastReviewed: Date;
  structuredData: object;
  pagefindMeta?: string;
}

const { title, description, breadcrumbs, lastReviewed, structuredData, pagefindMeta } = Astro.props;
---

<BaseLayout title={title} description={description} structuredData={structuredData}>
  <div class="container">
    <Breadcrumb items={breadcrumbs} />
    <div class="content-layout">
      <article class="content-main" data-pagefind-body {...(pagefindMeta ? { 'data-pagefind-meta': pagefindMeta } : {})}>
        <slot />
      </article>
      <aside class="content-sidebar" data-pagefind-ignore>
        <slot name="sidebar" />
      </aside>
    </div>
    <footer class="content-footer">
      <p>Last reviewed: <time datetime={lastReviewed.toISOString()}>
        {lastReviewed.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
      </time></p>
    </footer>
  </div>
</BaseLayout>

<style>
  .content-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
    padding: var(--space-6) 0;
  }

  .content-main {
    min-width: 0;
  }

  .content-sidebar {
    background: var(--color-surface);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
  }

  .content-footer {
    border-top: 1px solid var(--color-border-light);
    padding: var(--space-4) 0;
    margin-top: var(--space-8);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  @media (min-width: 1024px) {
    .content-layout {
      grid-template-columns: 1fr var(--sidebar-width);
    }

    .content-sidebar {
      position: sticky;
      top: 5rem;
      align-self: start;
    }
  }
</style>
