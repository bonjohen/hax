---
import EvidenceBadge from './EvidenceBadge.astro';
import { EFFORT_LABELS, type EffortLevel } from '../lib/taxonomy';

interface Props {
  slug: string;
  title: string;
  oneLineClaim: string;
  evidenceLevel: 'high' | 'moderate' | 'preliminary' | 'mixed_contested' | 'narrative_conceptual';
  timeCostMinutes: number;
  effort: string;
  clusters: string[];
  behaviors: string[];
  goals: string[];
}

const { slug, title, oneLineClaim, evidenceLevel, timeCostMinutes, effort, clusters, behaviors, goals } = Astro.props;
---

<a
  href={`/experiments/${slug}/`}
  class="experiment-card"
  data-clusters={clusters.join(',')}
  data-behavior={behaviors.join(',')}
  data-goal={goals.join(',')}
  data-evidence={evidenceLevel}
  data-time={String(timeCostMinutes)}
  data-effort={effort}
>
  <h3 class="card-title">{title}</h3>
  <p class="card-claim">{oneLineClaim}</p>
  <div class="card-meta">
    <EvidenceBadge level={evidenceLevel} showTooltip={false} />
    <span class="card-time">{timeCostMinutes} min</span>
    <span class="card-effort">{EFFORT_LABELS[effort as EffortLevel]} effort</span>
  </div>
</a>

<style>
  .experiment-card {
    display: block;
    padding: var(--space-4);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    text-decoration: none;
    color: var(--color-text);
    transition: box-shadow 0.15s, border-color 0.15s;
  }

  .experiment-card:hover {
    border-color: var(--color-link);
    box-shadow: var(--shadow-md);
  }

  .card-title {
    font-size: var(--text-lg);
    margin: 0 0 var(--space-2);
  }

  .card-claim {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin: 0 0 var(--space-3);
    line-height: var(--leading-relaxed);
  }

  .card-meta {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    flex-wrap: wrap;
  }

  .card-time,
  .card-effort {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    padding: var(--space-1) var(--space-2);
    background: var(--color-surface);
    border-radius: var(--radius-sm);
  }
</style>
