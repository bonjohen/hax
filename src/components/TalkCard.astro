---
import EvidenceBadge from './EvidenceBadge.astro';

interface Props {
  slug: string;
  title: string;
  speaker: string;
  thumbnail?: string;
  evidenceLevel: 'high' | 'moderate' | 'preliminary' | 'mixed_contested' | 'narrative_conceptual';
  clusters: string[];
  behaviors?: string[];
  goals?: string[];
}

const { slug, title, speaker, thumbnail, evidenceLevel, clusters, behaviors = [], goals = [] } = Astro.props;
---

<a
  href={`/talks/${slug}/`}
  class="talk-card"
  data-clusters={clusters.join(',')}
  data-evidence={evidenceLevel}
  data-behavior={behaviors.join(',')}
  data-goal={goals.join(',')}
>
  <div class="card-thumbnail">
    {thumbnail ? (
      <img src={thumbnail} alt="" loading="lazy" />
    ) : (
      <div class="thumbnail-placeholder" aria-hidden="true">
        <svg viewBox="0 0 24 24" width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.5">
          <polygon points="5,3 19,12 5,21" />
        </svg>
      </div>
    )}
  </div>
  <div class="card-body">
    <h3 class="card-title">{title}</h3>
    <p class="card-speaker">{speaker}</p>
    <EvidenceBadge level={evidenceLevel} showTooltip={false} />
  </div>
</a>

<style>
  .talk-card {
    display: block;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    text-decoration: none;
    color: var(--color-text);
    overflow: hidden;
    transition: box-shadow 0.15s, border-color 0.15s;
  }

  .talk-card:hover {
    border-color: var(--color-link);
    box-shadow: var(--shadow-md);
  }

  .card-thumbnail img {
    width: 100%;
    height: auto;
    display: block;
  }

  .thumbnail-placeholder {
    background: var(--color-surface);
    display: flex;
    align-items: center;
    justify-content: center;
    height: 8rem;
    color: var(--color-text-muted);
  }

  .card-body {
    padding: var(--space-3) var(--space-4);
  }

  .card-title {
    font-size: var(--text-base);
    margin: 0 0 var(--space-1);
    line-height: var(--leading-tight);
  }

  .card-speaker {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin: 0 0 var(--space-2);
  }
</style>
