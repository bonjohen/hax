---

<footer class="site-footer no-print">
  <div class="container footer-inner">
    <nav aria-label="Footer navigation">
      <ul class="footer-nav">
        <li><a href="/about/">About</a></li>
        <li><a href="/resources/">Resources</a></li>
      </ul>
    </nav>
    <div class="footer-legal">
      <p class="footer-copyright">&copy; {new Date().getFullYear()} HAx. All rights reserved.</p>
      <p class="footer-attribution">HAx is not affiliated with TED. TED Talk content is the property of TED Conferences, LLC.</p>
      <p class="footer-noncommercial">This site is a non-commercial educational resource.</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--color-border);
    background: var(--color-surface);
    padding: var(--space-8) 0;
    margin-top: var(--space-16);
  }

  .footer-inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .footer-nav {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: var(--space-6);
  }

  .footer-nav a {
    color: var(--color-text-muted);
    text-decoration: none;
    font-size: var(--text-sm);
    font-weight: 500;
  }

  .footer-nav a:hover {
    color: var(--color-link);
  }

  .footer-legal {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }

  .footer-legal p {
    margin: 0 0 var(--space-1);
  }

  @media (min-width: 640px) {
    .footer-inner {
      flex-direction: row;
      justify-content: space-between;
      align-items: flex-start;
    }
  }
</style>
