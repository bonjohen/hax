---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
---

<BaseLayout
  title="Home"
  description="Discover actionable, evidence-rated experiments drawn from TED Talks."
>
  <div class="container">
    <Breadcrumb items={[{ label: 'Home', href: '/' }]} />
    <section class="hero">
      <h1>HAx — Human Advantage Experiments</h1>
      <p>Discover actionable, evidence-rated experiments drawn from TED Talks. Browse by topic cluster, find what matches your goals, and try something backed by real research.</p>
    </section>
  </div>
</BaseLayout>

<style>
  .hero {
    padding: var(--space-12) 0;
  }

  .hero h1 {
    font-size: var(--text-4xl);
    margin-bottom: var(--space-4);
  }

  .hero p {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    max-width: var(--content-width);
  }
</style>
