---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ExperimentCard from '../components/ExperimentCard.astro';

const experiments = await getCollection('experiments');
const talks = await getCollection('talks');
const clusters = await getCollection('clusters');

const clusterColors: Record<string, string> = {
  body: 'var(--color-cluster-body)',
  cognition: 'var(--color-cluster-cognition)',
  environment: 'var(--color-cluster-environment)',
  social: 'var(--color-cluster-social)',
};

const clusterIcons: Record<string, string> = {
  body: 'M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z',
  cognition: 'M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 17h-2v-2h2v2zm2.07-7.75l-.9.92C13.45 12.9 13 13.5 13 15h-2v-.5c0-1.1.45-2.1 1.17-2.83l1.24-1.26c.37-.36.59-.86.59-1.41 0-1.1-.9-2-2-2s-2 .9-2 2H8c0-2.21 1.79-4 4-4s4 1.79 4 4c0 .88-.36 1.68-.93 2.25z',
  environment: 'M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5',
  social: 'M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z',
};

// Pick 3 featured experiments with highest evidence
const featured = experiments
  .filter(e => e.data.evidence_level === 'high' || e.data.evidence_level === 'moderate')
  .slice(0, 3);
---

<BaseLayout
  title="Home"
  description="Discover actionable, evidence-rated experiments drawn from TED Talks."
>
  <!-- Hero -->
  <section class="hero">
    <div class="container hero-inner">
      <div class="hero-content">
        <p class="hero-overline">Evidence-rated experiments from TED Talks</p>
        <h1 class="hero-title">Turn inspiring ideas into<br /><span class="hero-highlight">actionable experiments</span></h1>
        <p class="hero-description">HAx curates experiments from the world's best talks and rates each one against published research. Browse by topic, find what fits your goals, and try something backed by real science.</p>
        <div class="hero-actions">
          <a href="/experiments/" class="btn btn-primary">Browse Experiments</a>
          <a href="/about/" class="btn btn-ghost">How It Works</a>
        </div>
        <div class="hero-stats">
          <div class="stat">
            <span class="stat-number">{experiments.length}</span>
            <span class="stat-label">Experiments</span>
          </div>
          <div class="stat">
            <span class="stat-number">{talks.length}</span>
            <span class="stat-label">TED Talks</span>
          </div>
          <div class="stat">
            <span class="stat-number">{clusters.length}</span>
            <span class="stat-label">Topic Clusters</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Clusters -->
  <section class="clusters-section">
    <div class="container">
      <div class="section-heading">
        <span class="section-overline">Explore by Topic</span>
        <h2>Four Clusters of Human Performance</h2>
      </div>
      <div class="cluster-grid">
        {clusters.map((c) => (
          <a href={`/clusters/${c.data.id}/`} class="cluster-card" style={`--cluster-color: ${clusterColors[c.data.id] || 'var(--color-link)'}`}>
            <div class="cluster-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" width="28" height="28" fill="currentColor">
                <path d={clusterIcons[c.data.id] || clusterIcons.body} />
              </svg>
            </div>
            <h3 class="cluster-name">{c.data.name}</h3>
            <p class="cluster-count">{c.data.hero_experiments.length} featured experiments</p>
            <span class="cluster-arrow" aria-hidden="true">&rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Featured Experiments -->
  {featured.length > 0 && (
    <section class="featured-section">
      <div class="container">
        <div class="section-heading">
          <span class="section-overline">Get Started</span>
          <h2>Featured Experiments</h2>
        </div>
        <div class="featured-grid">
          {featured.map((exp) => (
            <ExperimentCard
              slug={exp.id}
              title={exp.data.title}
              oneLineClaim={exp.data.one_line_claim}
              evidenceLevel={exp.data.evidence_level}
              timeCostMinutes={exp.data.time_cost_minutes}
              effort={exp.data.effort}
              clusters={exp.data.clusters}
              behaviors={exp.data.behaviors}
              goals={exp.data.goals}
            />
          ))}
        </div>
        <div class="section-cta">
          <a href="/experiments/" class="btn btn-secondary">View All {experiments.length} Experiments &rarr;</a>
        </div>
      </div>
    </section>
  )}

  <!-- CTA Banner -->
  <section class="cta-banner">
    <div class="container cta-inner">
      <h2 class="cta-title">Not sure where to start?</h2>
      <p class="cta-description">Pick a persona that matches your goals and get a curated set of experiments to try.</p>
      <a href="/personas/" class="btn btn-primary">Find Your Persona</a>
    </div>
  </section>
</BaseLayout>

<style>
  /* Buttons */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-6);
    border-radius: var(--radius-md);
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    text-decoration: none;
    transition: all var(--transition-base);
    cursor: pointer;
    border: none;
  }

  .btn-primary {
    background: var(--gradient-accent);
    color: var(--color-text-inverse);
    box-shadow: 0 2px 8px rgba(67, 97, 238, 0.3);
  }

  .btn-primary:hover {
    box-shadow: 0 4px 16px rgba(67, 97, 238, 0.4);
    transform: translateY(-1px);
    color: var(--color-text-inverse);
  }

  .btn-ghost {
    background: transparent;
    color: var(--color-dark-text);
    border: 1px solid var(--color-dark-border);
  }

  .btn-ghost:hover {
    background: rgba(255, 255, 255, 0.08);
    color: var(--color-text-inverse);
    border-color: rgba(255, 255, 255, 0.3);
  }

  .btn-secondary {
    background: var(--color-surface);
    color: var(--color-link);
    border: 1px solid var(--color-border);
  }

  .btn-secondary:hover {
    background: var(--color-link);
    color: var(--color-text-inverse);
    border-color: var(--color-link);
  }

  /* Hero */
  .hero {
    background: var(--gradient-hero);
    color: var(--color-dark-text);
    padding: var(--space-16) 0 var(--space-20);
    position: relative;
    overflow: hidden;
  }

  .hero::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -20%;
    width: 60%;
    height: 200%;
    background: radial-gradient(ellipse, rgba(67, 97, 238, 0.15) 0%, transparent 70%);
    pointer-events: none;
  }

  .hero-inner {
    position: relative;
    z-index: 1;
  }

  .hero-content {
    max-width: 40rem;
  }

  .hero-overline {
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wider);
    color: var(--color-accent);
    margin-bottom: var(--space-4);
  }

  .hero-title {
    font-size: var(--text-4xl);
    font-weight: var(--weight-extrabold);
    color: var(--color-text-inverse);
    line-height: var(--leading-tight);
    margin-bottom: var(--space-6);
  }

  .hero-highlight {
    background: var(--gradient-warm);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-description {
    font-size: var(--text-lg);
    color: var(--color-dark-muted);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-8);
    max-width: 36rem;
  }

  .hero-actions {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
    margin-bottom: var(--space-10);
  }

  .hero-stats {
    display: flex;
    gap: var(--space-8);
    border-top: 1px solid var(--color-dark-border);
    padding-top: var(--space-6);
  }

  .stat {
    display: flex;
    flex-direction: column;
  }

  .stat-number {
    font-size: var(--text-2xl);
    font-weight: var(--weight-bold);
    color: var(--color-text-inverse);
  }

  .stat-label {
    font-size: var(--text-xs);
    color: var(--color-dark-muted);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wider);
  }

  @media (min-width: 640px) {
    .hero {
      padding: var(--space-20) 0 var(--space-24);
    }

    .hero-title {
      font-size: var(--text-5xl);
    }
  }

  /* Clusters Section */
  .clusters-section {
    padding: var(--space-16) 0;
  }

  .cluster-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
  }

  .cluster-card {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-5) var(--space-6);
    background: var(--color-surface-raised);
    border: 1px solid var(--color-border-light);
    border-radius: var(--radius-lg);
    text-decoration: none;
    color: var(--color-text);
    transition: all var(--transition-base);
    box-shadow: var(--shadow-card);
    position: relative;
    overflow: hidden;
  }

  .cluster-card::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 4px;
    background: var(--cluster-color);
  }

  .cluster-card:hover {
    box-shadow: var(--shadow-card-hover);
    transform: translateY(-2px);
    border-color: var(--cluster-color);
    color: var(--color-text);
  }

  .cluster-icon {
    flex-shrink: 0;
    width: 3rem;
    height: 3rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-md);
    background: color-mix(in srgb, var(--cluster-color) 12%, transparent);
    color: var(--cluster-color);
  }

  .cluster-name {
    font-size: var(--text-lg);
    font-weight: var(--weight-semibold);
    margin: 0;
    flex: 1;
  }

  .cluster-count {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin: 0;
    display: none;
  }

  .cluster-arrow {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    transition: transform var(--transition-fast);
  }

  .cluster-card:hover .cluster-arrow {
    transform: translateX(4px);
    color: var(--cluster-color);
  }

  @media (min-width: 640px) {
    .cluster-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .cluster-card {
      flex-direction: column;
      align-items: flex-start;
      padding: var(--space-6);
      padding-left: calc(var(--space-6) + 4px);
    }

    .cluster-name {
      font-size: var(--text-xl);
    }

    .cluster-count {
      display: block;
    }

    .cluster-arrow {
      align-self: flex-end;
    }
  }

  @media (min-width: 1024px) {
    .cluster-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  /* Featured Experiments */
  .featured-section {
    padding: var(--space-16) 0;
    background: var(--color-surface);
  }

  .featured-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
    margin-bottom: var(--space-8);
  }

  @media (min-width: 640px) {
    .featured-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (min-width: 1024px) {
    .featured-grid { grid-template-columns: repeat(3, 1fr); }
  }

  .section-cta {
    text-align: center;
  }

  /* CTA Banner */
  .cta-banner {
    padding: var(--space-16) 0;
  }

  .cta-inner {
    text-align: center;
    max-width: 32rem;
    margin: 0 auto;
  }

  .cta-title {
    font-size: var(--text-3xl);
    margin-bottom: var(--space-4);
  }

  .cta-description {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    margin-bottom: var(--space-6);
  }
</style>
