---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';

const resources = await getCollection('resources');
const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Resources', href: '/resources/' },
];
---

<BaseLayout title="Resources" description="Curated resources, study links, and TED playlists for further exploration.">
  <div class="container">
    <Breadcrumb items={breadcrumbs} />
    <article class="prose">
      <h1>Resources</h1>
      <p class="lead">Further reading, curated playlists, and research links related to HAx experiments.</p>

      {resources.length > 0 && (
        <section>
          <h2>Curated Links</h2>
          <ul class="resource-list">
            {resources.map((r) => (
              <li>
                {r.data.url ? (
                  <a href={r.data.url} target="_blank" rel="noopener noreferrer">{r.data.title}</a>
                ) : (
                  <span>{r.data.title}</span>
                )}
                <span class="resource-type">{r.data.type}</span>
              </li>
            ))}
          </ul>
        </section>
      )}
    </article>
  </div>
</BaseLayout>

<style>
  .prose {
    max-width: var(--content-width);
    padding: var(--space-8) 0;
  }
  .lead {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    margin-bottom: var(--space-8);
  }
  .resource-list {
    list-style: none;
    padding: 0;
  }
  .resource-list li {
    padding: var(--space-3) 0;
    border-bottom: 1px solid var(--color-border);
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }
  .resource-type {
    font-size: var(--text-xs);
    padding: var(--space-1) var(--space-2);
    background: var(--color-surface);
    border-radius: var(--radius-sm);
    color: var(--color-text-muted);
  }
</style>
