---
import { getCollection, getEntry, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import ExperimentCard from '../../components/ExperimentCard.astro';
import { collectionPageJsonLd } from '../../lib/structured-data';

export async function getStaticPaths() {
  const personas = await getCollection('personas');
  return personas.map((p) => ({ params: { id: p.data.id }, props: { persona: p } }));
}

const { persona } = Astro.props;
const { Content } = await render(persona);

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Personas', href: '/personas/' },
  { label: persona.data.persona_name, href: `/personas/${persona.data.id}/` },
];

// Resolve recommended experiments
const experiments = await Promise.all(
  persona.data.recommended_experiments.map((id: string) => getEntry('experiments', id))
);
const resolvedExperiments = experiments.filter(Boolean);

// Resolve recommended clusters
const clusters = await Promise.all(
  persona.data.recommended_clusters.map((id: string) => getEntry('clusters', id))
);
const resolvedClusters = clusters.filter(Boolean);

const siteUrl = import.meta.env.SITE || 'https://hax.example.com';
const structuredData = collectionPageJsonLd(
  persona.data.persona_name,
  `${siteUrl}/personas/${persona.data.id}/`,
  resolvedExperiments.map(e => ({ title: e.data.title, collection: 'experiments', slug: e.id })),
  siteUrl
);
---

<BaseLayout title={persona.data.persona_name} description={`Curated experiments for the "${persona.data.persona_name}" persona.`} structuredData={structuredData}>
  <div class="container">
    <Breadcrumb items={breadcrumbs} />
    <div class="persona-page">
      <header class="persona-header">
        <h1>{persona.data.persona_name}</h1>
        <p class="persona-meta">{resolvedExperiments.length} experiments across {resolvedClusters.length} clusters</p>
      </header>

      <div class="persona-content">
        <Content />
      </div>

      <section class="persona-experiments">
        <h2>Recommended Experiments</h2>
        <div class="card-grid">
          {resolvedExperiments.map((exp) => (
            <ExperimentCard
              slug={exp.id}
              title={exp.data.title}
              oneLineClaim={exp.data.one_line_claim}
              evidenceLevel={exp.data.evidence_level}
              timeCostMinutes={exp.data.time_cost_minutes}
              effort={exp.data.effort}
              clusters={exp.data.clusters}
              behaviors={exp.data.behaviors}
              goals={exp.data.goals}
            />
          ))}
        </div>
      </section>

      {resolvedClusters.length > 0 && (
        <section class="persona-clusters">
          <h2>Related Clusters</h2>
          <div class="cluster-links">
            {resolvedClusters.map((c) => (
              <a href={`${base}/clusters/${c.data.id}/`} class="cluster-link">{c.data.name}</a>
            ))}
          </div>
        </section>
      )}
    </div>
  </div>
</BaseLayout>

<style>
  .persona-page {
    padding-bottom: var(--space-12);
  }
  .persona-header {
    padding-top: var(--space-8);
    margin-bottom: var(--space-8);
  }
  .persona-meta {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
  }
  .persona-content {
    max-width: var(--content-width);
    margin-bottom: var(--space-12);
    line-height: var(--leading-relaxed);
  }
  .persona-content :global(h2) {
    font-size: var(--text-xl);
    margin-top: var(--space-8);
    padding-bottom: var(--space-2);
    border-bottom: 2px solid var(--color-border-light);
  }
  .persona-content :global(p) {
    color: var(--color-text);
  }
  .persona-experiments {
    margin-bottom: var(--space-12);
  }
  .persona-experiments h2 {
    margin-bottom: var(--space-6);
  }
  .card-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
  }
  @media (min-width: 640px) { .card-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .card-grid { grid-template-columns: repeat(3, 1fr); } }
  .persona-clusters h2 {
    margin-bottom: var(--space-4);
  }
  .cluster-links {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
  }
  .cluster-link {
    padding: var(--space-2) var(--space-4);
    background: var(--color-surface);
    border: 1px solid var(--color-border-light);
    border-radius: var(--radius-md);
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: var(--color-link);
    text-decoration: none;
    transition: all var(--transition-base);
  }
  .cluster-link:hover {
    background: var(--color-link);
    color: var(--color-text-inverse);
    border-color: var(--color-link);
  }
</style>
