---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const personas = await getCollection('personas');
const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Personas', href: '/personas/' },
];
---

<BaseLayout title="Personas" description="Find experiments curated for your goals and role.">
  <div class="container">
    <Breadcrumb items={breadcrumbs} />
    <h1>Personas</h1>
    <p class="lead">Not sure where to start? Pick the persona closest to your goals.</p>
    <div class="persona-grid">
      {personas.map((p) => (
        <a href={`${base}/personas/${p.data.id}/`} class="persona-link">
          <h2>{p.data.persona_name}</h2>
          <p>{p.data.recommended_clusters.length} clusters &middot; {p.data.recommended_experiments.length} experiments</p>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  h1 { margin-top: var(--space-8); }
  .lead {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    margin-bottom: var(--space-8);
    max-width: var(--content-width);
    line-height: var(--leading-relaxed);
  }
  .persona-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(16rem, 1fr));
    gap: var(--space-4);
    margin-bottom: var(--space-12);
  }
  .persona-link {
    display: block;
    padding: var(--space-6);
    background: var(--color-surface-raised);
    border: 1px solid var(--color-border-light);
    border-radius: var(--radius-lg);
    text-decoration: none;
    color: var(--color-text);
    transition: all var(--transition-base);
    box-shadow: var(--shadow-card);
    position: relative;
    overflow: hidden;
  }
  .persona-link::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: var(--gradient-warm);
  }
  .persona-link:hover {
    border-color: var(--color-accent);
    box-shadow: var(--shadow-card-hover);
    transform: translateY(-2px);
    color: var(--color-text);
  }
  .persona-link h2 {
    font-size: var(--text-xl);
    font-weight: var(--weight-bold);
    margin: 0 0 var(--space-2);
  }
  .persona-link p {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin: 0;
  }
</style>
